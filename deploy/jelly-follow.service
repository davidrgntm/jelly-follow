[Unit]
Description=Jelly Follow API + Bot
After=network.target

[Service]
Type=simple
User=jelly
Group=jelly
WorkingDirectory=/home/jelly/jelly-follow
EnvironmentFile=/home/jelly/jelly-follow/.env
ExecStart=/home/jelly/jelly-follow/venv/bin/uvicorn app.main:app \
    --host 0.0.0.0 \
    --port 8000 \
    --workers 1
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
