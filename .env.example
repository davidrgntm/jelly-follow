BOT_TOKEN=123456:telegram_bot_token
BASE_URL=https://api.follow.jelly.uz
TRACKING_DOMAIN=https://go.jelly.uz
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/app/google_credentials.json
# or use GOOGLE_SERVICE_ACCOUNT_JSON={...json...}
SPREADSHEET_NAME=Jelly Follow - PROD
SPREADSHEET_ID=
SHEETS_SHARE_EMAILS=
DEFAULT_TIMEZONE=Asia/Tashkent
APP_ENV=production
BOT_MODE=webhook
BOOTSTRAP_ON_START=false
SEED_SUPER_ADMIN_ON_START=false
SUPER_ADMIN_TELEGRAM_ID=123456789
INTERNAL_SECRET=change_this
ADMIN_WEB_SECRET=change_this_web
WEB_SESSION_SECRET=change_this_session
INSTAGRAM_UZ_USERNAME=jelly.uz
INSTAGRAM_RU_USERNAME=jelly.ru
INSTAGRAM_KG_USERNAME=jelly.kg
INSTAGRAM_AZ_USERNAME=jelly.az

# Database
DB_BACKEND=sqlite
SQLITE_PATH=data/jelly_follow.db
SQLITE_TIMEOUT=30
SQLITE_IMPORT_ON_START=false
